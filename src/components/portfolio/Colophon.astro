---
/* Colofão. Texto vem do dicionário único (src/data/portfolio.ts).
   #to-top é ligado por portfolio-v2.js. */
import { t } from '../../data/portfolio';
---

<footer class="colophon sheet" data-screen-label="Colofão">
  <div class="in">
    <p data-i18n="f.colo">{t('f.colo')}</p>
    <p>
      <a href="/freela" data-umami-event="freela_nav" data-umami-event-from="home"
        >tem um negócio? proposta pra empresas →</a
      >
    </p>
    <p class="metrics-note" data-i18n="f.metrics">{t('f.metrics')}</p>
  </div>
  {/* aba flutuante (position:fixed) — fora do fluxo do colofão */}
  <button type="button" id="to-top" data-i18n="f.top">{t('f.top')}</button>
</footer>
