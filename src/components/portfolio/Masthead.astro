---
/* Masthead do portfólio. Contrato com portfolio-v2-motion.js:
   .masthead, .brand, .meta-row, .name .l1/.l2, .stamp, .mast-foot, .tail, .mono. */
---

<header class="masthead sheet" data-screen-label="Masthead">
  <div class="head-band">
    <a class="brand" href="/" aria-label="edugenes — início">
      <img src="/brand/simbolo-duotone.svg" alt="" height="28" />
      <span class="brand-word">edugenes<span class="brand-cursor">_</span></span>
    </a>
    <div class="meta-row">
      <span data-i18n="m.doc">Portfólio — rev. 02 / 2026</span>
      <span>Fortaleza, CE — 3°43′S 38°32′W</span>
      <span class="now" data-comment-anchor="clock"
        ><span data-i18n="m.now">agora, hora local</span> — <b id="clock">--:--:--</b></span
      >
      <span class="lang"><a id="lang-pt" class="on">PT</a> / <a id="lang-en">EN</a></span>
    </div>
  </div>

  <h1 class="name">
    <span class="l1">Eduardo</span>
    <span class="l2">Genes <span class="stamp" data-i18n="m.stamp">em produção</span></span>
  </h1>

  <div class="mast-foot">
    <p class="tail" data-i18n="m.tail">
      Desenvolvedor web — front-end em primeiro lugar, full stack quando o problema pede. Hoje na IMTS Group.
    </p>
    <span class="mono" data-i18n="m.since">escrevendo interfaces desde 2022</span>
  </div>
</header>
