---
/* Masthead do portfólio. Texto vem do dicionário único (src/data/portfolio.ts) —
   o HTML do build é idêntico ao que o motor aplicaria (sem flash de troca).
   Contrato com portfolio-v2-motion.js:
   .masthead, .brand, .meta-row, .name .l1/.l2, .stamp, .mast-foot, .tail, .mono. */
import { t } from '../../data/portfolio';
---

<header class="masthead sheet" data-screen-label="Masthead">
  <div class="head-band">
    <a class="brand" href="/" aria-label="edugenes — início">
      <img src="/brand/simbolo-duotone.svg" alt="" height="28" />
      <span class="brand-word">edugenes<span class="brand-cursor">_</span></span>
    </a>
    <div class="meta-row">
      <span data-i18n="m.doc">{t('m.doc')}</span>
      <span>Fortaleza, CE — 3°43′S 38°32′W</span>
      <span class="now" data-comment-anchor="clock"
        ><span data-i18n="m.now">{t('m.now')}</span> — <b id="clock">--:--:--</b></span
      >
      <span class="lang"
        ><button type="button" id="lang-pt" class="on" aria-pressed="true">PT</button> / <button
          type="button"
          id="lang-en"
          aria-pressed="false">EN</button
        ></span
      >
    </div>
  </div>

  <h1 class="name">
    <span class="l1">Eduardo</span>
    <span class="l2">Genes <span class="stamp" data-i18n="m.stamp">{t('m.stamp')}</span></span>
  </h1>

  <div class="mast-foot">
    <p class="tail" data-i18n="m.tail">{t('m.tail')}</p>
    <span class="mono" data-i18n="m.since">{t('m.since')}</span>
  </div>
</header>
