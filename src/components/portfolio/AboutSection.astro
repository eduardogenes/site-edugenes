---
/* 03 Sobre. #about-txt é renderizado no cliente (i18n); a foto é tratada
   por filtro CSS conforme o tweak congelado (photo-pb no body). */
---

<section class="sec sheet" id="sobre" data-screen-label="03 Sobre">
  <div class="sec-head">
    <h2><span class="no">03</span><span data-i18n="toc.3">Sobre</span></h2>
  </div>
  <div class="about2">
    <div class="txt" id="about-txt"></div>
    <figure class="fig">
      <picture>
        <source srcset="/retrato.avif" type="image/avif" />
        <img
          id="profile-photo"
          src="/retrato.webp"
          alt="Eduardo Genes — retrato"
          width="640"
          height="853"
          loading="lazy"
          decoding="async"
        />
      </picture>
      <figcaption data-i18n="a.cap">Fortaleza, 2026</figcaption>
    </figure>
  </div>
</section>
