---
import Base from '../layouts/Base.astro';
---

<Base
  title="Eduardo Genes — Sites & sistemas pra seu negócio"
  description="Sites, lojas e sistemas sob medida pra pequenos negócios, profissionais liberais e hotéis. Feito por quem cuida do design e do código. Fortaleza e remoto."
  canonical="https://edugenes.com.br/freela"
  ogTitle="Eduardo Genes — Sites & sistemas pra seu negócio"
  ogDescription="Seu negócio, no ar. Proposta fechada em até 48h — Fortaleza e todo o Brasil."
  ogImage="https://edugenes.com.br/assets/og-freela.png"
  bodyClass="intro"
  bootCmd="./print proposta --rev 01 --ink red"
>
  <Fragment slot="head">
    <style is:inline>
      /* extras da página freela */
      /* título mais longo que o do portfólio — escala própria pra caber numa linha */
      .name .l1,.name .l2{font-size:clamp(46px,10.6vw,136px);}
      .masthead .name{margin-top:clamp(36px,5vw,58px);}
      .wa-cta{
        display:inline-flex;align-items:baseline;gap:14px;background:var(--ink);color:var(--paper);
        text-decoration:none;padding:20px 30px;font-weight:800;font-stretch:112%;text-transform:uppercase;
        font-size:clamp(18px,2.4vw,28px);letter-spacing:-.01em;border:1.5px solid var(--ink);
        transition:background .15s,color .15s;
      }
      .wa-cta small{font-family:var(--f-mono);font-size:11px;letter-spacing:.1em;font-weight:400;opacity:.75;}
      .wa-cta:hover{background:var(--red);border-color:var(--red);}
      .wa-row{display:flex;gap:18px;align-items:center;flex-wrap:wrap;margin-top:36px;}
      .wa-alt{font-family:var(--f-serif);font-style:italic;font-size:16.5px;color:var(--ink-2);}
      .wa-alt a{color:var(--ink);}
      .wa-alt a:hover{color:var(--red);}
      .pkg{display:grid;grid-template-columns:1fr 1fr;gap:0 64px;}
      .pkg-note{font-family:var(--f-serif);font-style:italic;font-size:17.5px;color:var(--ink-2);margin:34px 0 0;max-width:64ch;}
      .pkg-note b{color:var(--red);font-style:normal;font-family:var(--f-disp);font-weight:700;}
      .svc-deliv{list-style:none;margin:0;padding:0;}
      .svc-deliv li{padding:7px 0;border-top:1px dotted var(--ink-2);font-size:15.5px;display:flex;gap:10px;}
      .svc-deliv li::before{content:"—";color:var(--red);flex:none;}
      .svc-deliv li:first-child{border-top:0;}
      .svc-meta{font-family:var(--f-mono);font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-2);margin-top:18px;}
      .svc-meta b{color:var(--red);font-weight:500;}
      .proof-line{font-family:var(--f-serif);font-style:italic;font-size:15.5px;margin-top:14px;}
      .proof-line a{font-style:normal;font-weight:600;text-decoration:underline;text-underline-offset:3px;}
      .proof-line a:hover{color:var(--red);}
      @media (max-width:760px){.pkg{grid-template-columns:1fr;gap:30px;}}
    </style>
  </Fragment>

  <!-- ================= MASTHEAD ================= -->
  <header class="masthead sheet" data-screen-label="Masthead Freela">
    <div class="meta-row">
      <span>Proposta comercial — 2026</span>
      <span>Fortaleza, CE &amp; remoto</span>
      <span>WhatsApp +55 85 98109-7155</span>
      <span class="lang"><a href="/">ver portfólio →</a></span>
    </div>

    <h1 class="name">
      <span class="l1">Seu negócio,</span>
      <span class="l2">no ar. <span class="stamp">respondo hoje</span></span>
    </h1>

    <div class="mast-foot">
      <p class="tail">
        Sites, lojas e sistemas sob medida — feitos por <strong>Eduardo Genes</strong>, desenvolvedor que cuida
        do design e do código. Sem template, sem agência no meio.
      </p>
      <span class="mono">atendendo Fortaleza e todo o Brasil</span>
    </div>
  </header>

  <!-- ================= ÍNDICE ================= -->
  <nav class="toc sheet" data-screen-label="Índice Freela">
    <ol>
      <li>
        <a href="#servicos"
          ><span class="no">01</span><span>O que eu faço</span><span class="leader"></span><span class="pg"
            >5 serviços</span
          ></a
        >
      </li>
      <li>
        <a href="#como"
          ><span class="no">02</span><span>Como funciona</span><span class="leader"></span><span class="pg"
            >4 passos</span
          ></a
        >
      </li>
      <li>
        <a href="#provas"
          ><span class="no">03</span><span>Provas</span><span class="leader"></span><span class="pg"
            >trabalho real</span
          ></a
        >
      </li>
      <li>
        <a href="#orcamento"
          ><span class="no">04</span><span>Pedir proposta</span><span class="leader"></span><span class="pg"
            >2 min</span
          ></a
        >
      </li>
    </ol>
  </nav>

  <!-- ================= 01 SERVIÇOS ================= -->
  <section class="sec sheet" id="servicos" data-screen-label="01 Serviços">
    <div class="sec-head">
      <h2><span class="no">01</span>O que eu faço</h2>
      <p class="note">Clique numa linha pra ver o que entra em cada serviço.</p>
    </div>
    <div class="windex" id="svc-index"></div>

    <div class="creds2 pkg">
      <div>
        <h4>Pacote Essencial</h4>
        <div class="citem">
          <div>
            <div class="cm">Pra entrar no ar rápido</div>
            <div class="cs">
              Página única ou site enxuto, design próprio, publicado e funcionando — domínio, hospedagem e
              Google incluídos.
            </div>
          </div>
        </div>
      </div>
      <div>
        <h4>Pacote Completo</h4>
        <div class="citem">
          <div>
            <div class="cm">Presença que trabalha por você</div>
            <div class="cs">
              Site multi-páginas com SEO, conteúdo que você mesmo atualiza, métricas de visitas e
              acompanhamento pós-entrega.
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="pkg-note">
      <b>Sem surpresa:</b> todo projeto recebe uma proposta fechada em documento — escopo, prazo e investimento
      por escrito antes de qualquer pagamento. O valor depende do tamanho do projeto, e você sabe tudo antes de
      decidir.
    </p>
  </section>

  <!-- ================= 02 COMO FUNCIONA ================= -->
  <section class="sec sheet" id="como" data-screen-label="02 Como funciona">
    <div class="sec-head">
      <h2><span class="no">02</span>Como funciona</h2>
      <p class="note">Do jeito que for mais fácil pra você — reunião, áudio ou texto.</p>
    </div>
    <div class="ledger">
      <div class="lrow">
        <div class="lw">Passo 01</div>
        <div>
          <h3>Você me conta o que precisa</h3>
          <div class="org">reunião rápida, áudio ou um texto corrido — como preferir</div>
          <p>
            Não precisa chegar com nada pronto. Me diz o que seu negócio faz e o que você quer que aconteça
            (mais clientes, pedidos, agendamentos) — eu transformo isso em escopo.
          </p>
        </div>
        <div class="lm">→ resposta no mesmo dia</div>
      </div>
      <div class="lrow">
        <div class="lw">Passo 02</div>
        <div>
          <h3>Proposta em documento</h3>
          <div class="org">escopo, prazo e investimento — por escrito</div>
          <p>
            Você recebe uma proposta clara: o que será feito, em quanto tempo e por quanto. Sem letra miúda,
            sem mensalidade escondida.
          </p>
        </div>
        <div class="lm">→ em até 48h</div>
      </div>
      <div class="lrow">
        <div class="lw">Passo 03</div>
        <div>
          <h3>Desenvolvimento à vista</h3>
          <div class="org">você acompanha o site crescendo</div>
          <p>
            Updates frequentes com link de prévia — você opina cedo e o resultado sai do seu jeito, não do meu.
            Uma landing simples sai em poucos dias; projetos maiores recebem cronograma.
          </p>
        </div>
        <div class="lm"></div>
      </div>
      <div class="lrow">
        <div class="lw">Passo 04</div>
        <div>
          <h3>No ar — e funcionando</h3>
          <div class="org">publicação, domínio e treinamento incluídos</div>
          <p>
            Entrego publicado, com domínio configurado, Google encontrando seu site e você sabendo mexer no que
            precisa. E sempre com mais do que foi combinado.
          </p>
        </div>
        <div class="lm">→ suporte pós-entrega</div>
      </div>
    </div>
  </section>

  <!-- ================= 03 PROVAS ================= -->
  <section class="sec sheet" id="provas" data-screen-label="03 Provas">
    <div class="sec-head">
      <h2><span class="no">03</span>Provas</h2>
      <p class="note">Trabalho real, no ar, que você pode conferir agora.</p>
    </div>
    <div class="ledger">
      <div class="lrow">
        <div class="lw">Cliente real</div>
        <div>
          <h3>W.VIANA Arquitetura</h3>
          <div class="org">site institucional — escritório de arquitetura e interiores</div>
          <p>Portfólio de projetos, rápido no celular e encontrável no Google. No ar com domínio próprio.</p>
          <p class="proof-line">
            <a href="https://wvianaarquitetura.com.br" target="_blank" rel="noopener"
              >wvianaarquitetura.com.br ↗</a
            > — abre aí e confere.
          </p>
          <!-- DEPOIMENTO W.VIANA — descomente quando tiver a frase real da arquiteta:
          <blockquote class="quote2">
            <p>“FRASE REAL DA CLIENTE AQUI.”</p>
            <cite>— Nome da arquiteta, W.VIANA Arquitetura</cite>
          </blockquote>
          -->
        </div>
        <div class="lm">→ em produção</div>
      </div>
      <div class="lrow">
        <div class="lw">Dia a dia</div>
        <div>
          <h3>Plataforma educacional Método TRON</h3>
          <div class="org">via IMTS Group — vendida a colégios pelo Brasil</div>
          <p>
            No meu trabalho fixo, encabeço o UX/UI de uma plataforma de ensino multitenant com IA e
            gamificação. É esse nível de cuidado que aplico no seu projeto.
          </p>
        </div>
        <div class="lm">→ edtech nacional</div>
      </div>
    </div>
    <p class="pkg-note">
      Mais projetos — incluindo sistemas, dashboards e apps — no <a href="/" style="font-weight:600;"
        >portfólio completo →</a
      >
    </p>
  </section>

  <!-- ================= 04 PEDIR PROPOSTA ================= -->
  <section class="sec sheet" id="orcamento" data-screen-label="04 Pedir proposta">
    <div class="sec-head">
      <h2><span class="no">04</span>Pedir proposta</h2>
    </div>
    <p class="contact2-lead">
      Me chama no WhatsApp e me conta o que você precisa — texto ou áudio. Proposta fechada em até 48h, sem
      compromisso.
    </p>
    <div class="wa-row">
      <a
        class="wa-cta"
        href="https://wa.me/5585981097155?text=Oi%2C%20Eduardo!%20Tenho%20um%20neg%C3%B3cio%20e%20quero%20uma%20proposta.%20Ele%20%C3%A9%20assim%3A%20"
        target="_blank"
        rel="noopener">Chamar no WhatsApp <small>85 98109-7155</small></a
      >
      <span class="wa-alt"
        >ou por e-mail: <a href="mailto:eduardogenes95@gmail.com?subject=Proposta%20para%20meu%20neg%C3%B3cio"
          >eduardogenes95@gmail.com</a
        ></span
      >
    </div>
  </section>

  <!-- ================= COLOFÃO ================= -->
  <footer class="colophon sheet" data-screen-label="Colofão Freela">
    <div class="in">
      <p>
        Eduardo Genes · desenvolvedor web · Fortaleza, Brasil · este site também é trabalho meu — feito à mão,
        sem template
      </p>
      <p><a id="to-top">↑ voltar ao topo</a></p>
    </div>
  </footer>

  <script is:inline>
    (function () {
      'use strict';
      var SVC = [
        {
          ti: 'Site pro seu negócio', ty: 'ser encontrado e passar confiança', yr: 'carro-chefe',
          desc: 'O cartão de visita que trabalha 24h: quem te procura no Google encontra um site bonito, rápido no celular e com suas informações certas.',
          deliv: ['Design feito pra sua marca — nada de template', 'Perfeito no celular, onde seu cliente está', 'Google encontrando seu negócio (SEO básico)', 'Domínio, hospedagem e publicação incluídos', 'Botão de WhatsApp direto pro seu atendimento'],
          meta: 'Prazo típico: <b>1 a 3 semanas</b>, conforme o tamanho', proof: '<a href="https://wvianaarquitetura.com.br" target="_blank" rel="noopener">veja um no ar: wvianaarquitetura.com.br ↗</a>'
        },
        {
          ti: 'Landing page', ty: 'campanha, lançamento, captação', yr: 'mais rápido',
          desc: 'Uma página, um objetivo: transformar visitante em contato. Pra anúncio, promoção, evento ou captação de clientes.',
          deliv: ['Texto e design focados em conversão', 'Formulário ou WhatsApp como destino', 'Métricas: você sabe quantos clicaram', 'Publicada e rodando — pronta pra receber tráfego'],
          meta: 'Prazo típico: <b>a partir de 3 dias</b>'
        },
        {
          ti: 'Loja & catálogo', ty: 'vitrine com pedidos', yr: 'vendas',
          desc: 'Seu catálogo organizado, com fotos e preços, e o pedido caindo direto no seu WhatsApp — ou com pagamento online, se fizer sentido.',
          deliv: ['Catálogo que você mesmo atualiza', 'Pedidos via WhatsApp ou checkout com pagamento', 'Frete, variações e promoções conforme o caso'],
          meta: 'Prazo típico: <b>2 a 4 semanas</b>'
        },
        {
          ti: 'Sistema sob medida', ty: 'a planilha vira sistema', yr: 'sob escopo',
          desc: 'Orçamentos, agendamentos, controle de pedidos, dashboards: aquele processo que hoje vive em planilha e papel vira um sistema com login, feito pro seu fluxo.',
          deliv: ['Levantamento do seu processo antes de codar', 'Sistema web com login e níveis de acesso', 'Treinamento da equipe incluído', 'Evolui por etapas — começa pequeno, cresce com o uso'],
          meta: 'Prazo e investimento: <b>definidos na proposta</b>, por escopo'
        },
        {
          ti: 'Manutenção & melhorias', ty: 'seu site já existe, mas parou no tempo', yr: 'contínuo',
          desc: 'Site lento, desatualizado ou que ninguém sabe mexer? Eu assumo: atualizo, acelero e deixo redondo — sem você precisar refazer tudo.',
          deliv: ['Diagnóstico honesto: conserto ou refaço, te digo qual', 'Performance e Google (velocidade + SEO)', 'Atualizações de conteúdo e pequenas evoluções'],
          meta: 'Formato: <b>por demanda ou combo mensal</b>'
        }
      ];

      var box = document.getElementById('svc-index');
      SVC.forEach(function (s, i) {
        var row = document.createElement('div');
        row.className = 'wrow';
        row.innerHTML =
          '<button class="wrow-btn" aria-expanded="false">' +
            '<span class="no">' + String(i + 1).padStart(2, '0') + '</span>' +
            '<span class="ti">' + s.ti + '</span>' +
            '<span class="ty">' + s.ty + '</span>' +
            '<span class="yr">' + s.yr + '</span>' +
            '<span class="pm">+</span>' +
          '</button>' +
          '<div class="wbody"><div class="wbody-in" style="grid-template-columns:1fr;">' +
            '<div>' +
              '<p class="wdesc">' + s.desc + '</p>' +
              '<ul class="svc-deliv" style="margin-top:20px;">' + s.deliv.map(function (d) { return '<li>' + d + '</li>'; }).join('') + '</ul>' +
              '<p class="svc-meta">' + s.meta + '</p>' +
              (s.proof ? '<p class="proof-line">' + s.proof + '</p>' : '') +
            '</div>' +
          '</div></div>';
        row.querySelector('.wrow-btn').addEventListener('click', function () {
          var open = row.classList.toggle('open');
          this.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
        box.appendChild(row);
      });

      document.getElementById('to-top').addEventListener('click', function () { window.scrollTo({ top: 0, behavior: 'smooth' }); });
    })();
  </script>
  <script is:inline src="/js/portfolio-v2-motion.js"></script>
  <script is:inline src="/js/portfolio-v2-scrollmotion.js"></script>
</Base>
